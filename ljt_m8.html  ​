<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>三百秒沉思 · 思维刻度</title>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background-color: #0a0a14;
        }
        #info {
            position: absolute;
            top: 30px;
            left: 0;
            width: 100%;
            text-align: center;
            color: rgba(220, 240, 255, 0.9);
            text-shadow: 0 0 20px #4a80ff, 0 0 40px #b07aff;
            z-index: 10;
            pointer-events: none;
            user-select: none;
            animation: softGlow 3s infinite alternate;
            letter-spacing: 4px;
            font-weight: 200;
            font-size: 1.2rem;
        }
        #counter-panel {
            position: absolute;
            bottom: 15%;
            left: 50%;
            transform: translateX(-50%);
            z-index: 20;
            background: rgba(10, 10, 30, 0.5);
            backdrop-filter: blur(8px);
            padding: 20px 50px;
            border-radius: 60px;
            border: 1px solid rgba(100, 180, 255, 0.3);
            box-shadow: 0 0 50px rgba(70, 130, 255, 0.3);
            text-align: center;
            pointer-events: none;
            color: white;
            font-weight: 300;
            letter-spacing: 2px;
        }
        #depth-display {
            font-size: 4rem;
            font-weight: 400;
            background: linear-gradient(45deg, #a0d0ff, #ffb8d9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 30px #6a8cff;
            line-height: 1.2;
        }
        #depth-label {
            font-size: 1rem;
            opacity: 0.7;
            letter-spacing: 6px;
            margin-top: 5px;
            color: #ccd9ff;
        }
        #command-hint {
            position: absolute;
            bottom: 5%;
            right: 5%;
            color: rgba(180, 200, 255, 0.5);
            font-size: 0.8rem;
            z-index: 15;
            background: rgba(0,0,0,0.3);
            padding: 8px 18px;
            border-radius: 40px;
            backdrop-filter: blur(3px);
            border: 1px solid rgba(255,255,255,0.15);
            pointer-events: none;
            letter-spacing: 1px;
        }
        #command-hint span {
            color: #aaf0ff;
            font-weight: 400;
        }
        @keyframes softGlow {
            0% { opacity: 0.6; filter: drop-shadow(0 0 5px #5588ff); }
            100% { opacity: 1; filter: drop-shadow(0 0 25px #aa88ff); }
        }
        .click-effect {
            position: absolute;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: radial-gradient(circle, #fff, #a0c0ff);
            pointer-events: none;
            z-index: 100;
            transform: translate(-50%, -50%);
            animation: clickRipple 1s ease-out forwards;
        }
        @keyframes clickRipple {
            0% { width: 0px; height: 0px; opacity: 1; }
            100% { width: 150px; height: 150px; opacity: 0; }
        }
        canvas {
            display: block;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1;
        }
    </style>
</head>
<body>
    <div id="info">⚡ 内 在 命 令 · 沉 思 三 百 秒 ⚡</div>
    <div id="counter-panel">
        <div id="depth-display">0/300</div>
        <div id="depth-label">思 考 深 度</div>
    </div>
    <div id="command-hint">💬 <span>点击 或 按空格键</span>  ·  积累思考</div>

    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.128.0/build/three.module.js"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';

        // --- 初始化场景 ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x0a0a18);
        
        const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(0, 2, 16);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.shadowMap.enabled = false; // 不需要阴影
        document.body.appendChild(renderer.domElement);

        // --- 灯光 (虽然点材质不需要，但为了将来可能添加的物体) ---
        const ambientLight = new THREE.AmbientLight(0x404060);
        scene.add(ambientLight);
        const pointLight = new THREE.PointLight(0x88aaff, 1, 30);
        pointLight.position.set(2, 3, 8);
        scene.add(pointLight);

        // --- 背景星群 ---
        const starsGeo = new THREE.BufferGeometry();
        const starsCount = 1200;
        const starsPos = new Float32Array(starsCount * 3);
        for (let i = 0; i < starsCount; i++) {
            starsPos[i*3] = (Math.random() - 0.5) * 200;
            starsPos[i*3+1] = (Math.random() - 0.5) * 200;
            starsPos[i*3+2] = (Math.random() - 0.5) * 200 - 30;
        }
        starsGeo.setAttribute('position', new THREE.BufferAttribute(starsPos, 3));
        const starsMat = new THREE.PointsMaterial({
            color: 0xaaccff,
            size: 0.18,
            blending: THREE.AdditiveBlending,
            transparent: true,
            opacity: 0.5
        });
        const stars = new THREE.Points(starsGeo, starsMat);
        scene.add(stars);

        // --- 主要的光环粒子 (代表300秒刻度) ---
        const totalSeconds = 300;
        const radius = 5.2;
        const particlesGeo = new THREE.BufferGeometry();
        const initialPositions = new Float32Array(totalSeconds * 3);
        const colors = new Float32Array(totalSeconds * 3);
        
        // 存储每个粒子的角度，用于后续动画
        const angles = new Array(totalSeconds);
        
        for (let i = 0; i < totalSeconds; i++) {
            const angle = (i / totalSeconds) * Math.PI * 2;
            angles[i] = angle;
            const x = Math.cos(angle) * radius;
            const y = Math.sin(angle) * radius * 0.4; // 稍微压扁，形成椭圆
            const z = Math.sin(angle) * 0.8; // 轻微深度变化
            
            initialPositions[i*3] = x;
            initialPositions[i*3+1] = y;
            initialPositions[i*3+2] = z;
            
            // 初始颜色：暗蓝紫色 (未点亮状态)
            const r = 0.2 + 0.1 * Math.sin(angle*2);
            const g = 0.2 + 0.2 * Math.cos(angle);
            const b = 0.6 + 0.3 * Math.sin(angle);
            colors[i*3] = r;
            colors[i*3+1] = g;
            colors[i*3+2] = b;
        }
        
        particlesGeo.setAttribute('position', new THREE.BufferAttribute(initialPositions, 3));
        particlesGeo.setAttribute('color', new THREE.BufferAttribute(colors, 3));
        
        // 创建圆形粒子纹理
        const canvas = document.createElement('canvas');
        canvas.width = 32;
        canvas.height = 32;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.beginPath();
        ctx.arc(16, 16, 14, 0, 2 * Math.PI);
        ctx.fill();
        ctx.globalCompositeOperation = 'source-atop';
        const gradient = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);
        gradient.addColorStop(0, 'rgba(255,255,255,1)');
        gradient.addColorStop(0.5, 'rgba(180,200,255,0.9)');
        gradient.addColorStop(1, 'rgba(160,160,255,0)');
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, 32, 32);
        const particleMap = new THREE.CanvasTexture(canvas);
        
        const particlesMat = new THREE.PointsMaterial({
            size: 0.35,
            map: particleMap,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
            vertexColors: true,
            transparent: true,
            sizeAttenuation: true
        });
        
        const particleRing = new THREE.Points(particlesGeo, particlesMat);
        scene.add(particleRing);

        // --- 中心能量球 (随着思考深度变化) ---
        const coreGeo = new THREE.SphereGeometry(0.8, 32, 16);
        const coreMat = new THREE.MeshStandardMaterial({
            color: 0x3a5f9e,
            emissive: 0x1a2f5a,
            roughness: 0.3,
            metalness: 0.1,
            transparent: true,
            opacity: 0.9
        });
        const coreSphere = new THREE.Mesh(coreGeo, coreMat);
        scene.add(coreSphere);

        // 围绕中心的小光点
        const sparklesGeo = new THREE.BufferGeometry();
        const sparklesPos = new Float32Array(60 * 3);
        for (let i = 0; i < 60; i++) {
            const r = 1.2 + Math.random()*0.5;
            const theta = Math.random() * Math.PI*2;
            const phi = Math.acos(2*Math.random()-1);
            sparklesPos[i*3] = r * Math.sin(phi)*Math.cos(theta);
            sparklesPos[i*3+1] = r * Math.sin(phi)*Math.sin(theta);
            sparklesPos[i*3+2] = r * Math.cos(phi);
        }
        sparklesGeo.setAttribute('position', new THREE.BufferAttribute(sparklesPos, 3));
        const sparklesMat = new THREE.PointsMaterial({ color: 0xffdd99, size: 0.08, blending: THREE.AdditiveBlending });
        const sparkles = new THREE.Points(sparklesGeo, sparklesMat);
        scene.add(sparkles);

        // --- 思考深度状态 ---
        let currentDepth = 0; // 0-300
        const depthColors = []; // 存储每个粒子被点亮时的目标颜色 (暖色)
        for (let i = 0; i < totalSeconds; i++) {
            const hue = 0.10 + (i / totalSeconds) * 0.2; // 金色到橙红
            const col = new THREE.Color().setHSL(hue, 1.0, 0.65);
            depthColors.push([col.r, col.g, col.b]);
        }

        // --- 更新UI和粒子颜色的函数 ---
        function updateDepth(inc = 1) {
            if (currentDepth >= totalSeconds) return false;
            
            const newDepth = Math.min(currentDepth + inc, totalSeconds);
            
            // 点亮从 currentDepth 到 newDepth-1 的粒子
            const colorAttr = particlesGeo.attributes.color;
            const array = colorAttr.array;
            for (let i = currentDepth; i < newDepth; i++) {
                const idx = i * 3;
                array[idx] = depthColors[i][0];
                array[idx+1] = depthColors[i][1];
                array[idx+2] = depthColors[i][2];
            }
            colorAttr.needsUpdate = true;
            
            currentDepth = newDepth;
            
            // 更新UI
            document.getElementById('depth-display').innerHTML = `${currentDepth}/300`;
            
            // 根据深度改变中心球颜色
            const progress = currentDepth / totalSeconds;
            coreSphere.material.emissive.setHSL(0.1 + progress * 0.3, 0.9, 0.2 + progress * 0.3);
            coreSphere.material.color.setHSL(0.6 - progress * 0.3, 0.8, 0.5);
            
            // 达到300时触发狂欢效果
            if (currentDepth === totalSeconds) {
                triggerCompletion();
            }
            
            return true;
        }

        // --- 完成特效 ---
        function triggerCompletion() {
            // 让所有粒子变得更亮，大小变化
            particlesMat.size = 0.6;
            // 闪烁中心
            coreSphere.scale.set(1.5, 1.5, 1.5);
            setTimeout(() => coreSphere.scale.set(1, 1, 1), 500);
            
            // 添加临时烟花粒子 (简单模拟)
            const burstGeo = new THREE.BufferGeometry();
            const burstCount = 400;
            const burstPos = new Float32Array(burstCount * 3);
            for (let i = 0; i < burstCount; i++) {
                const r = 0.5 + Math.random()*5;
                const theta = Math.random() * Math.PI*2;
                const phi = Math.acos(2*Math.random()-1);
                burstPos[i*3] = r * Math.sin(phi)*Math.cos(theta);
                burstPos[i*3+1] = r * Math.sin(phi)*Math.sin(theta);
                burstPos[i*3+2] = r * Math.cos(phi);
            }
            burstGeo.setAttribute('position', new THREE.BufferAttribute(burstPos, 3));
            const burstMat = new THREE.PointsMaterial({ color: 0xffaa88, size: 0.15, blending: THREE.AdditiveBlending });
            const burst = new THREE.Points(burstGeo, burstMat);
            scene.add(burst);
            
            setTimeout(() => {
                scene.remove(burst);
                particlesMat.size = 0.35; // 恢复
            }, 800);
        }

        // --- 交互效果 (点击波纹) ---
        function addClickRipple(x, y) {
            const ripple = document.createElement('div');
            ripple.className = 'click-effect';
            ripple.style.left = x + 'px';
            ripple.style.top = y + 'px';
            document.body.appendChild(ripple);
            setTimeout(() => ripple.remove(), 1000);
        }

        // --- 事件监听 ---
        window.addEventListener('click', (e) => {
            if (currentDepth < totalSeconds) {
                updateDepth(1);
                addClickRipple(e.clientX, e.clientY);
            }
        });

        window.addEventListener('keydown', (e) => {
            if (e.code === 'Space' && currentDepth < totalSeconds) {
                e.preventDefault(); // 防止页面滚动
                updateDepth(1);
                // 在屏幕中央添加波纹
                addClickRipple(window.innerWidth/2, window.innerHeight/2);
            }
        });

        // 触摸设备支持
        window.addEventListener('touchstart', (e) => {
            if (currentDepth < totalSeconds && e.touches.length) {
                e.preventDefault();
                updateDepth(1);
                const touch = e.touches[0];
                addClickRipple(touch.clientX, touch.clientY);
            }
        }, { passive: false });

        // --- 鼠标移动影响相机 (轻微视差) ---
        let mouseX = 0, mouseY = 0;
        window.addEventListener('mousemove', (e) => {
            mouseX = (e.clientX / window.innerWidth) * 2 - 1;
            mouseY = -(e.clientY / window.innerHeight) * 2 + 1;
        });

        // --- 动画变量 ---
        let time = 0;

        // --- 动画循环 ---
        function animate() {
            requestAnimationFrame(animate);
            time += 0.005;

            // 相机轻微跟随鼠标
            camera.position.x += (mouseX * 2.5 - camera.position.x) * 0.02;
            camera.position.y += (mouseY * 1.5 + 2 - camera.position.y) * 0.02;
            camera.lookAt(0, 0.5, 0);

            // 旋转光环
            particleRing.rotation.y += 0.001;
            particleRing.rotation.x += 0.0005;
            
            // 中心球体呼吸效果
            coreSphere.scale.setScalar(1 + Math.sin(time * 5) * 0.03);
            
            // 背景星星缓慢旋转
            stars.rotation.y += 0.0002;
            stars.rotation.x += 0.0001;
            
            // 围绕的小光点旋转
            sparkles.rotation.y += 0.005;
            sparkles.rotation.x += 0.003;

            renderer.render(scene, camera);
        }

        animate();

        // --- 窗口大小自适应 ---
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        // 显示初始状态
        document.getElementById('depth-display').innerHTML = `0/300`;
    </script>
</body>
</html>
